# Base URL del API admin (incluye /api/admin). Ej. php artisan serve → http://127.0.0.1:8000/api/admin
VITE_API_URL=http://127.0.0.1:8000/api/admin

# Opcional: raíz pública de Laravel para /storage/ (adjuntos de soporte, imágenes).
# Si no se define, se deduce de VITE_API_URL (sin /api/admin). No usar el puerto de Vite (8002).
# VITE_BACKEND_BASE_URL=http://127.0.0.1:8000

# Pusher: copiar PUSHER_APP_KEY y PUSHER_APP_CLUSTER del backend. Ambas obligatorias para
# conectar; vacías o ausentes = la app no abre conexión Echo.
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=
